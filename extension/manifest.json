{
  "manifest_version": 3,
  "name": "TraceZ — Safe Browsing Shield",
  "description": "Lightweight phishing detection and safe browsing protection. Privacy-first.",
  "version": "1.0.0",
  "permissions": [
    "storage",
    "alarms",
    "webNavigation",
    "notifications"
  ],
  "optional_permissions": [
    "downloads"
  ],
  "host_permissions": [
    "http://localhost:8000/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "content/page-analyzer.js"
      ],
      "css": [
        "assets/warning-banner.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "options_page": "options/options.html",
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none'"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "assets/blocked-page.html",
        "assets/warning-banner.css"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
